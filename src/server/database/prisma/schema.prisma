generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Branch {
  id                   String         @id
  name                 String         @unique
  primaryProfessionals Professional[] @relation("ProfessionalPrimaryBranch")
  sales                Sale[]
  expenses             Expense[]
}

model Professional {
  id              String                     @id
  name            String
  role            String?
  primaryBranchId String?
  branchIdsJson   String                     @default("[]")
  active          Boolean                    @default(true)
  commissionMode  ProfessionalCommissionMode @default(SYSTEM_RULES)
  commissionValue Int?
  phone           String?
  email           String?
  notes           String?
  avatarColor     String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @default(now()) @updatedAt
  primaryBranch   Branch?                    @relation("ProfessionalPrimaryBranch", fields: [primaryBranchId], references: [id], onDelete: SetNull)
  sales           Sale[]

  @@index([primaryBranchId])
}

model Service {
  id    String @id
  name  String @unique
  price Int
  sales Sale[]
}

model Sale {
  id             String       @id
  date           DateTime
  branchId       String
  professionalId String
  serviceId      String
  clientName     String?
  total          Int
  commission     Int
  profit         Int
  commissionType CommissionType @default(FIXED)
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([branchId])
  @@index([professionalId])
  @@index([serviceId])
}

model Expense {
  id        String      @id
  title     String      @default("Gasto")
  type      ExpenseType @default(VARIABLE)
  date      DateTime
  branchId  String
  category  String
  amount    Int
  monthlyAmount Int?
  active    Boolean     @default(true)
  prorationMode ExpenseProrationMode?
  paymentStatus PaymentStatus @default(PENDING)
  paidAmount Int @default(0)
  paidDate DateTime?
  paymentMethod String?
  paymentNote String?
  paymentProofName String?
  paymentProofDataUrl String?
  dueDate DateTime?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([branchId])
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum ExpenseType {
  FIXED
  VARIABLE
}

enum ExpenseProrationMode {
  CALENDAR_DAYS
  OPERATING_DAYS
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum ProfessionalCommissionMode {
  SYSTEM_RULES
  PERCENTAGE
  FIXED
  MIXED
  NONE
}
