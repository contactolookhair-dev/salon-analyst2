generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Branch {
  id            String         @id
  name          String         @unique
  professionals Professional[]
  sales         Sale[]
  expenses      Expense[]
}

model Professional {
  id       String @id
  name     String
  branchId String
  role     String?
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([branchId])
}

model Service {
  id    String @id
  name  String @unique
  price Int
  sales Sale[]
}

model Sale {
  id             String       @id
  date           DateTime
  branchId       String
  professionalId String
  serviceId      String
  clientName     String?
  total          Int
  commission     Int
  profit         Int
  commissionType CommissionType @default(FIXED)
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([branchId])
  @@index([professionalId])
  @@index([serviceId])
}

model Expense {
  id       String   @id
  date     DateTime
  branchId String
  category String
  amount   Int
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([branchId])
}

enum CommissionType {
  PERCENTAGE
  FIXED
}
